{
    "compilerOptions": {
        "target": "ES6",
        "module": "node16",
        "esModuleInterop": true,
        "moduleResolution": "node16",
        "skipLibCheck": true,
        "noEmit": true,
        "useUnknownInCatchVariables": false,
        "strict": true
    },
    "include": [
        "*.ts"
    ]
}