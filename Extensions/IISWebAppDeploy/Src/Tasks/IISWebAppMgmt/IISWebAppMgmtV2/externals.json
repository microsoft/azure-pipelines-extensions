{
    "taskModule": [{
        "name": "Sanitizer",
        "type": "powershell",
        "dest": "ps_modules"
    }],
    "nugetv2": {
        "VstsTaskSdk": {
            "version": "0.7.1",
            "repository": "https://mseng.pkgs.visualstudio.com/PipelineTools/_packaging/PipelineTools_PublicPackages/nuget/v2/",
            "cp": [
                {
                    "source": [
                        "*.ps1",
                        "*.psd1",
                        "*.psm1",
                        "lib.json"
                    ],
                    "dest": "VstsTaskSdk/"
                }
            ]
        },
        "RemoteDeployer": {
            "version": "0.1.0",
            "repository": "https://mseng.pkgs.visualstudio.com/PipelineTools/_packaging/PipelineTools_PublicPackages/nuget/v2/",
            "cp": [
                {
                    "source": [
                        "*.ps1",
                        "*.psd1",
                        "*.psm1",
                        "module.json",
                        "Strings"
                    ],
                    "dest": "RemoteDeployer/",
                    "options": "-R"
                }
            ]
        }
    }
}